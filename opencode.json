{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "brave-search": {
            "type": "local",
            "command": [
                "bash",
                "-c",
                "BRAVE_API_KEY=$(cat ~/.brave_search_key) npx -y @brave/brave-search-mcp-server"
            ],
            "enabled": true
        }
    },
    "permission": {
        "*": "ask",
        "bash": {
            "*": "ask",
            "git diff": "allow",
            "git diff *": "allow",
            "git log": "allow",
            "git log *": "allow",
            "git show": "allow",
            "git show *": "allow",
            "git status": "allow",
            "git status *": "allow",
            "git remote *": "allow",
            "git branch *": "allow",
            "git tag *": "allow",
            "git stash list": "allow",
            "git stash list *": "allow",
            "git rev-parse *": "allow",
            "git ls-files *": "allow",
            "git blame *": "allow",
            "git merge-base *": "allow",
            "ls": "allow",
            "ls *": "allow",
            "find *": "allow",
            "rg *": "allow",
            "grep": "allow",
            "grep *": "allow",
            "diff *": "allow",
            "file *": "allow",
            "stat *": "allow",
            "du *": "allow",
            "realpath *": "allow",
            "env": "allow",
            "env *": "allow",
            "pwd": "allow",
            "tree *": "allow",
            "echo *": "allow",
            "cat *": "allow",
            "sort *": "allow",
            "wc *": "allow",
            "head *": "allow",
            "tail *": "allow",
            "mkdir *": "allow",
            "touch *": "allow",
            "jq *": "allow",
            "which *": "allow",
            "date *": "allow",
            "basename *": "allow",
            "dirname *": "allow",
            "tr *": "allow",
            "cut *": "allow",
            "xargs *": "allow",
            "python3 -m py_compile *": "allow",
            "python3 *": "ask",
            "python -m py_compile *": "allow",
            "python *": "ask",
            "pip3 list *": "allow",
            "pip3 show *": "allow",
            "pip3 freeze *": "allow",
            "pip list *": "allow",
            "pip show *": "allow",
            "pip freeze *": "allow",
            "terraform plan *": "allow",
            "terraform init *": "allow",
            "terraform validate *": "allow",
            "terraform fmt *": "allow",
            "terraform output *": "allow",
            "terraform state list *": "allow",
            "terraform state show *": "allow",
            "terraform providers *": "allow",
            "docker images *": "allow",
            "docker ps *": "allow",
            "docker build *": "ask",
            "docker run *": "ask",
            "gh api */pulls/*/comments": "allow",
            "gh api *": "ask",
            "gh pr list": "allow",
            "gh pr list *": "allow",
            "gh pr view": "allow",
            "gh pr view *": "allow",
            "gh pr status": "allow",
            "gh pr status *": "allow",
            "gh pr checks *": "allow",
            "gh pr diff *": "allow",
            "gh pr create *": "ask",
            "gh issue list": "allow",
            "gh issue list *": "allow",
            "gh issue view *": "allow",
            "gh run list": "allow",
            "gh run list *": "allow",
            "gh run view *": "allow",
            "gh repo view": "allow",
            "gh repo view *": "allow",
            "gh search *": "allow",
            "gh auth status": "allow",
            "pre-commit run *": "allow",
            "sleep *": "allow",
            "sed *": "ask",
            "awk *": "ask",
            "curl *": "ask"
        },
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "skill": "allow",
        "task": {
            "explore": "allow",
            "general": "allow"
        },
        "todoread": "allow",
        "todowrite": "allow",
        "webfetch": "allow"
    }
}
